OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── 通义万相 Image Generation (Alibaba DashScope — works in mainland China) ────
# Sign up at: https://dashscope.aliyun.com  →  API-KEY管理 → 创建API-KEY
IMAGE_API_KEY=your_dashscope_api_key_here
# Optional overrides (defaults shown):
# IMAGE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# IMAGE_MODEL=wanx2.1-t2i-turbo

# Email notification (optional — leave blank to disable)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_RECEIVER=recipient@example.com

# Scheduler (default: 08:00 Beijing time)
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0
